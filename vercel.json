{
  "rewrites": [
    { "source": "/sync",            "destination": "/api/index" },
    { "source": "/setup",           "destination": "/api/index" },
    { "source": "/login",            "destination": "/api/index" },
    { "source": "/register",        "destination": "/api/index" },
    { "source": "/teacher/:path*",  "destination": "/api/index" },
    { "source": "/student/:path*",  "destination": "/api/index" },
    { "source": "/admin/:path*",    "destination": "/api/index" },
    { "source": "/(.*)",            "destination": "/index.html" }
  ]
}
